# Rust
/target/
**/*.rs.bk
*.pdb

# IDE
.idea/
.vscode/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Claude Code
.claude/settings.local.json

# Environment
.env
.env.*

# Coverage
coverage.xml
coverage.json
*.profraw
*.profdata

# Frontend (covered by frontend/.gitignore, belt-and-suspenders)
/frontend/node_modules/
/frontend/dist/

# Port config (local override)
.ports

