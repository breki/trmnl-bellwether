/.deploy
/bellwether-src.tar

# Local bellwether config and secrets (never commit)
/config.toml
windy_key.txt
ha_token.txt

# Playwright
/test-results/
/playwright-report/
/playwright/.cache/

# E2E test data (copied from fixtures at runtime)
/test-data/

# Node (root-level, for Playwright)
/node_modules/
/package-lock.json

# mise local overrides
.mise.local.toml
